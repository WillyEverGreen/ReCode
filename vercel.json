{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[...route]" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" },
    { "source": "/refunds", "destination": "/index.html" },
    { "source": "/shipping", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/cancellation-refund-policy", "destination": "/index.html" }
  ]
}
